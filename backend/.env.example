# Database
DATABASE_URL="postgresql://user:password@localhost:5432/magelang?schema=public"

# JWT Configuration
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRE="900"
REFRESH_TOKEN_EXPIRE="604800"

# Redis (Optional - fallback to memory cache if not available)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# OpenAI API
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Server
PORT=4000
NODE_ENV="development"

# Optional CORS allowlist for deployed frontend origins.
# Leave empty to allow all origins, or set comma-separated origins, for example:
# CORS_ORIGINS="https://magelangverse.vercel.app,https://www.magelangverse.id"
CORS_ORIGINS=""

# Optional S3 / S3-compatible object storage (used when S3_BUCKET is set)
# Example for DigitalOcean Spaces (set S3_ENDPOINT to https://nyc3.digitaloceanspaces.com)
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_ENDPOINT=""
# Optional public base URL for served objects (if different from S3 SDK URL)
S3_PUBLIC_URL=""
